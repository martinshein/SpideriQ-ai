# SpiderPublish Environment Variables
# Copy this file to .env and fill in your credentials

# Authentication (get credentials at admin@spideriq.ai)
SPIDERIQ_TOKEN=spideriq_pat_your_token_here

# API URL (default: production)
SPIDERIQ_API_URL=https://spideriq.ai

# Response format for AI agents (yaml saves 40-76% tokens)
SPIDERIQ_FORMAT=yaml
